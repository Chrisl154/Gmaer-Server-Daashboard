# Games Dashboard — Docker Compose environment variables
# Copy this file to .env and fill in the required values before running
# docker compose up.
#
# The installer sets these automatically. This file is for manual deployments.

# REQUIRED — Admin account password.
# Must be ≥12 characters and include uppercase, lowercase, digit, and special character.
# Example: GDASH_ADMIN_PASSWORD=MyStr0ng!Pass
GDASH_ADMIN_PASSWORD=

# Optional overrides (installer defaults shown)
LOG_LEVEL=info
